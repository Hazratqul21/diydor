# ── Diydor production stack (docker-compose.prod.yml) ──
# Nusxa: cp .env.docker.example .env.docker  va qiymatlarni to'ldiring.
# DATABASE_URL va REDIS_URL compose ichida avtomatik o'rnatiladi.

# PostgreSQL
POSTGRES_USER=diydor
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=diydor

# JWT — kuchli random: `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_random_64_hex
JWT_EXPIRES_IN=30d

# To'lov kalitlarini shifrlash (Payme key AES-256-GCM). Bo'sh bo'lsa JWT_SECRET ishlatiladi.
# Kuchli qiymat: `openssl rand -hex 32`
APP_ENCRYPTION_KEY=CHANGE_ME_random_64_hex

# Production CORS allowlist (vergul bilan). Same-origin (nginx proxy) bo'lsa ham
# Telegram/tashqi domenlar uchun to'ldiring. Masalan:
CORS_ORIGINS=https://diydorapp.uz,https://admin.diydorapp.uz

# Ilovaning ochiq (public) havolasi (Telegram push tugmalari uchun)
APP_PUBLIC_URL=https://diydorapp.uz

# Bosh admin (birinchi ishga tushishda seed qilinadi, idempotent)
ADMIN_EMAIL=admin@diydor.uz
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Telegram
TELEGRAM_BOT_TOKEN=

# Dev bypass (productionda bo'sh/false qoldiring — KUCHLI talab)
AUTH_DEV_BYPASS=false

# Eskiz SMS (hozircha o'chirilgan — sms.service.ts da ESKIZ_ENABLED=false)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# Payme
PAYME_MERCHANT_ID=
PAYME_KEY_TEST=
PAYME_KEY=
PAYME_ENV=test
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
