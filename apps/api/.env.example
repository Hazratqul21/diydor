# ── Database (root docker-compose.yml dagi portlar) ─────────────
DATABASE_URL="postgresql://diydor:diydor@localhost:5433/diydor?schema=public"
REDIS_URL="redis://localhost:6380"

# ── API ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Productionda ruxsat etilgan frontend manzillar (vergul bilan). Bo'sh = CORS yopiq.
CORS_ORIGINS="https://app.diydor.uz,https://admin.diydor.uz"

# ── Auth ────────────────────────────────────────────────────────
# JWT imzolash uchun maxfiy kalit (PRODUCTIONDA: openssl rand -hex 32)
JWT_SECRET="dev-secret-ozgartiring"
JWT_EXPIRES_IN="30d"

# Maxfiy qiymatlarni (Payme kaliti) bazada shifrlash uchun master kalit.
# PRODUCTIONDA majburiy: openssl rand -hex 32. Bo'sh bo'lsa JWT_SECRET'dan hosil qilinadi.
APP_ENCRYPTION_KEY=""

# Telegram bot tokeni (@BotFather dan). initData HMAC tekshiruvi uchun majburiy.
TELEGRAM_BOT_TOKEN=""
# Dev rejimida initData tekshiruvini chetlab o'tish (FAQAT lokal test — productionda kuchsiz).
AUTH_DEV_BYPASS=false

# ── Payme (Paycom Merchant API) ─────────────────────────────────
# ESLATMA: bu qiymatlarni admin panelidan ham kiritish mumkin (DB'da shifrlangan saqlanadi).
# Admin paneldagi qiymat ustun; bu .env faqat zaxira (fallback).
PAYME_MERCHANT_ID=""
PAYME_KEY_TEST=""
PAYME_KEY=""
PAYME_ENV="test"
PAYME_CHECKOUT_URL="https://checkout.test.paycom.uz"
